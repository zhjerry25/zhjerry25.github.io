---
import ViewCounter from "./ViewCounter.astro";

const { title, url, date, tags, label, description, translationKey, readingTime } = Astro.props;
---

<a
  href={url}
  class="block rounded-lg border border-neutral-200 p-4 hover:border-neutral-300 hover:bg-neutral-50 transition-colors"
  data-pagefind-ignore
>
  <div class="flex items-center gap-2 mb-1">
    {label && (
      <span class="text-xs font-medium text-pink-600 bg-pink-50 px-2 py-0.5 rounded">
        {label}
      </span>
    )}
    {date && (
      <span class="text-xs text-neutral-400">{date}</span>
    )}
    {tags && tags.length > 0 && (
      <span class="flex gap-1">
        {tags.map((tag: string) => (
          <span class="text-xs text-pink-600 bg-pink-50 px-1.5 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </span>
    )}
  </div>
  <div class="flex items-center justify-between gap-2">
    <h3 class="text-base font-medium text-gray-900 min-w-0 truncate">{title}</h3>
    <div class="flex items-center gap-2 shrink-0">
      {readingTime && (
        <span class="inline-flex items-center gap-1 text-xs text-neutral-400 whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor" aria-hidden="true"><!--!Font Awesome Free v7.3.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M464 256a208 208 0 1 1 -416 0 208 208 0 1 1 416 0zM0 256a256 256 0 1 0 512 0 256 256 0 1 0 -512 0zM232 120l0 136c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2 280 120c0-13.3-10.7-24-24-24s-24 10.7-24 24z"/></svg>
          {readingTime}
        </span>
      )}
      {translationKey && <ViewCounter translationKey={translationKey} />}
    </div>
  </div>
  {description && (
    <p class="text-sm text-neutral-500 mt-1 line-clamp-2">{description}</p>
  )}
</a>
