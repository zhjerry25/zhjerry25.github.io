---
import Menu from "./Menu.astro";
import { getAlternatePath, type Lang } from "../i18n/utils";
import type { Translations } from "../i18n/types";

interface Props {
  pageTitle: string;
  lang: Lang;
  t: Translations;
}

const { pageTitle, lang, t } = Astro.props;

const ROUTE_LABELS: Record<string, string> = {
  "/": t.header.breadcrumbHome,
  "/about": t.nav.about,
  "/notes": t.nav.notes,
  "/tags": t.nav.tags,
  "/recents": t.nav.recents,
  "/notes/chem": t.categories.chem,
  "/notes/cs": t.categories.cs,
  "/notes/mathphy": t.categories.mathphy,
  "/notes/others": t.categories.others,
  "/resources": t.nav.resources,
  "/Toolbox": t.nav.toolbox,
};

const pathname = Astro.url.pathname;
// Strip the language prefix for breadcrumb processing
const pathWithoutLang = pathname.replace(/^\/[a-z]{2}\//, "/");
const segments = pathWithoutLang.split("/").filter(Boolean);

const breadcrumbs: { label: string; href: string }[] = [];
let accumulated = "";
for (const seg of segments) {
  accumulated += "/" + seg;
  const label = ROUTE_LABELS[accumulated] || seg;
  breadcrumbs.push({ label, href: `/${lang}${accumulated}/` });
}

// Root path: show "Home"
if (breadcrumbs.length === 0) {
  breadcrumbs.push({ label: t.header.breadcrumbHome, href: `/${lang}/` });
}

// Override last segment with pageTitle if available (but not for root "Home Page")
if (pageTitle && pageTitle !== "Home Page" && pageTitle !== t.home.hero && breadcrumbs.length > 1) {
  breadcrumbs[breadcrumbs.length - 1].label = pageTitle;
}

const otherPath = getAlternatePath(pathname, lang);
---

<header
  class="sticky top-0 z-20 flex items-center gap-3 bg-pink-50 px-4 py-3 md:px-6"
>
  <!-- Mobile menu -->
  <div class="md:hidden shrink-0">
    <Menu />
  </div>

  <!-- Breadcrumbs -->
  <div class="flex-1 min-w-0 flex items-center gap-1.5 text-md">
    {breadcrumbs.map((item, i) => (
      i < breadcrumbs.length - 1 ? (
        <>
          <a
            href={item.href}
            class="text-neutral-400 hover:text-neutral-700 transition-colors truncate"
          >
            {item.label}
          </a>
          <span class="text-neutral-300 shrink-0">/</span>
        </>
      ) : (
        <span class="text-neutral-700 font-medium truncate">{item.label}</span>
      )
    ))}
  </div>

  <!-- Action buttons -->
  <div class="flex items-center gap-1 shrink-0">
    <button
      id="search-toggle"
      class="rounded-md p-2 text-neutral-500 hover:text-pink-700 cursor-pointer transition-colors"
      aria-label="Toggle search"
    >
      <svg class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true"><!--!Font Awesome Free v7.3.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376C296.3 401.1 253.9 416 208 416 93.1 416 0 322.9 0 208S93.1 0 208 0 416 93.1 416 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"/></svg>
    </button>

    <a
      id="lang-toggle"
      href={otherPath}
      class="rounded-md p-2 text-neutral-500 hover:text-pink-700 cursor-pointer transition-colors"
      aria-label={t.header.toggleLanguage}
    >
      <svg class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" aria-hidden="true"><!--!Font Awesome Free v7.3.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M160 0c17.7 0 32 14.3 32 32l0 32 128 0c17.7 0 32 14.3 32 32s-14.3 32-32 32l-9.6 0-8.4 23.1c-16.4 45.2-41.1 86.5-72.2 122 14.2 8.8 29 16.6 44.4 23.5l50.4 22.4 62.2-140c5.1-11.6 16.6-19 29.2-19s24.1 7.4 29.2 19l128 288c7.2 16.2-.1 35.1-16.2 42.2s-35.1-.1-42.2-16.2l-20-45-157.5 0-20 45c-7.2 16.2-26.1 23.4-42.2 16.2s-23.4-26.1-16.2-42.2l39.8-89.5-50.4-22.4c-23-10.2-45-22.4-65.8-36.4-21.3 17.2-44.6 32.2-69.5 44.7L78.3 380.6c-15.8 7.9-35 1.5-42.9-14.3s-1.5-35 14.3-42.9l34.5-17.3c16.3-8.2 31.8-17.7 46.4-28.3-13.8-12.7-26.8-26.4-38.9-40.9L81.6 224.7c-11.3-13.6-9.5-33.8 4.1-45.1s33.8-9.5 45.1 4.1l10.2 12.2c11.5 13.9 24.1 26.8 37.4 38.7 27.5-30.4 49.2-66.1 63.5-105.4l.5-1.2-210.3 0C14.3 128 0 113.7 0 96S14.3 64 32 64l96 0 0-32c0-17.7 14.3-32 32-32zM416 270.8L365.7 384 466.3 384 416 270.8z"/></svg>
    </a>

    <a
      id="source-toggle"
      href="https://github.com/zhjerry25"
      class="rounded-md p-2 text-neutral-500 hover:text-pink-700 cursor-pointer transition-colors"
      aria-label="Toggle source"
    >
      <svg class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" aria-hidden="true"><!--!Font Awesome Free v7.3.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M80 104a24 24 0 1 0 0-48 24 24 0 1 0 0 48zm80-24c0 32.8-19.7 61-48 73.3l0 70.7 176 0c26.5 0 48-21.5 48-48l0-22.7c-28.3-12.3-48-40.5-48-73.3 0-44.2 35.8-80 80-80s80 35.8 80 80c0 32.8-19.7 61-48 73.3l0 22.7c0 61.9-50.1 112-112 112l-176 0 0 70.7c28.3 12.3 48 40.5 48 73.3 0 44.2-35.8 80-80 80S0 476.2 0 432c0-32.8 19.7-61 48-73.3l0-205.3C19.7 141 0 112.8 0 80 0 35.8 35.8 0 80 0s80 35.8 80 80zm232 0a24 24 0 1 0 -48 0 24 24 0 1 0 48 0zM80 456a24 24 0 1 0 0-48 24 24 0 1 0 0 48z"/></svg>
    </a>
  </div>
</header>
