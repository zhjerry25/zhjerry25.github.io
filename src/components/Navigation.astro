---
import { Image } from "astro:assets";
import SidebarItem from "./SidebarItem.astro";
import SidebarSection from "./SidebarSection.astro";
import Social from "./Social.astro";
import type { Lang } from "../i18n/utils";
import type { Translations } from "../i18n/types";
import avatarImage from "../assets/images/avatar.png";

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;

const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  // Compare path without language prefix
  const currentNoLang = currentPath.replace(/^\/[a-z]{2}\//, "/");
  if (path === `/${lang}/`) return currentNoLang === "/";
  return currentNoLang.startsWith(path.replace(`/${lang}`, ""));
};
---

<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 flex w-64 -translate-x-full flex-col bg-brand-50 transition-transform duration-300 md:sticky md:top-0 md:h-screen md:translate-x-0"
>
  <!-- Logo -->
  <div class="flex items-center gap-2.5 px-4 py-4">
    <Image src={avatarImage} alt="Jerry" class="h-6 w-6 shrink-0 rounded-full object-cover" />
    <span class="text-[17px] font-semibold text-neutral-900">Jerry</span>
  </div>

  <nav class="flex-1 overflow-y-auto px-2 py-1">
