---
const { href, active = false, indented = false } = Astro.props;

const baseClasses = "flex items-center gap-2 rounded-md h-7 text-[14px] transition-colors";
const defaultClasses = "text-neutral-700 hover:bg-neutral-100";
const activeClasses = "bg-neutral-200 text-neutral-900 font-medium";
const indentClasses = indented ? "ml-5" : "px-2";
---

<li>
  <a
    href={href}
    class={`${baseClasses} ${active ? activeClasses : defaultClasses} ${indentClasses}`}
  >
    <slot />
  </a>
</li>
