---
interface Props {
  path: string;
  mode?: "card" | "full";
}

const { path, mode = "card" } = Astro.props;
const goatcounter = "zhjerry25";
const apiEn = `https://${goatcounter}.goatcounter.com/counter/en/notes/${encodeURIComponent(path)}.json`;
const apiZh = `https://${goatcounter}.goatcounter.com/counter/zh/notes/${encodeURIComponent(path)}.json`;
---

<span
  class="view-counter"
  data-api-en={apiEn}
  data-api-zh={apiZh}
  data-mode={mode}
>
  <span class="view-count-text">&mdash;</span>
</span>

<script is:inline>
  function loadViewCounts() {
    document.querySelectorAll(".view-counter").forEach((el) => {
      const apiEn = el.dataset.apiEn;
      const apiZh = el.dataset.apiZh;
      if (!apiEn || !apiZh) return;
      const mode = el.dataset.mode || "card";

      Promise.all([
        fetch(apiEn).then((r) => r.json()).catch(() => ({ count: "0" })),
        fetch(apiZh).then((r) => r.json()).catch(() => ({ count: "0" })),
      ])
        .then(([en, zh]) => {
          const total = (parseInt(en.count, 10) || 0) + (parseInt(zh.count, 10) || 0);
          const textEl = el.querySelector(".view-count-text");
          if (textEl) {
            if (mode === "card") {
              textEl.textContent = `\u{1F441} ${total}`;
            } else {
              textEl.textContent = `\u{1F441} ${total} views`;
            }
          }
        })
        .catch(() => {
          const textEl = el.querySelector(".view-count-text");
          if (textEl) textEl.textContent = "";
        });
    });
  }

  // Run on load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadViewCounts);
  } else {
    loadViewCounts();
  }
</script>

<style is:global>
  .view-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: #9ca3af;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .view-counter[data-mode="full"] {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 2rem;
    padding-top: 0;
  }
</style>
