---
import type { Lang } from "../i18n/utils";
import type { Translations } from "../i18n/types";

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang: _lang, t } = Astro.props;
---

<footer class="border-t border-neutral-200 mt-12">
  <div class="max-w-3xl mx-auto px-4 py-6 text-sm text-neutral-400 text-center">
    <p>{t.footer.copyright}</p>
    <p>{t.footer.icp}</p>
  </div>
</footer>
