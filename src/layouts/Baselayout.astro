---
import Header from "../components/Header.astro";
import Navigation from "../components/Navigation.astro";
import SearchModal from "../components/SearchModal.astro";
import Footer from "../components/footer.astro";
import SEO, { type OgImage } from "../components/SEO.astro";
import { getLocale, type Lang } from "../i18n/utils";
import type { Translations } from "../i18n/types";
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  pageTitle: string;
  showTitle?: boolean;
  searchable?: boolean;
  lang: Lang;
  t: Translations;
  seoDescription?: string;
  canonicalURL?: string;
  analyticsPath?: string;
  ogImage?: OgImage;
  seoType?: "website" | "article";
  pubDate?: Date;
  tags?: string[];
  isHome?: boolean;
}

const {
  pageTitle,
  showTitle = true,
  searchable = true,
  lang,
  t,
  seoDescription,
  canonicalURL,
  analyticsPath,
  ogImage,
  seoType = "website",
  pubDate,
  tags,
  isHome = false,
} = Astro.props;

const description = seoDescription || t.seo.homeDescription;
---

<html lang={getLocale(lang)}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${t.site.name} (${lang === "zh" ? "中文" : "English"})`} href={`/${lang}/rss.xml`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline data-goatcounter="https://zhjerry25.goatcounter.com/count"
            data-goatcounter-settings={analyticsPath ? JSON.stringify({ path: analyticsPath }) : undefined}
            async src="https://gc.zgo.at/count.js"></script>
    <SEO
      title={pageTitle}
      description={description}
      lang={lang}
      canonicalURL={canonicalURL || Astro.url.pathname}
      ogImage={ogImage}
      type={seoType}
      pubDate={pubDate}
      tags={tags}
    />
  </head>
  <body {...(!searchable ? { "data-pagefind-ignore": "" } : {})}>
    <div class="flex min-h-screen">
      <Navigation lang={lang} t={t} />

      <div
        id="overlay"
        class="fixed inset-0 z-30 hidden bg-black/50 md:hidden"
        aria-hidden="true"
      ></div>

      <div class="flex min-w-0 flex-1 flex-col">
        <Header pageTitle={pageTitle} lang={lang} t={t} isHome={isHome} />
        <main class="flex-1 px-4 py-6 md:px-8" {...(searchable ? { "data-pagefind-body": "" } : {})}>
          <div class="max-w-3xl mx-auto w-full">
            {showTitle && pageTitle && !isHome && (
              <h1 class="mb-6 text-2xl font-bold text-gray-900">{pageTitle}</h1>
            )}
            <slot />
          </div>
        </main>
        <Footer t={t} />
      </div>
    </div>

    <SearchModal t={t} />

    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>
