---
import BaseLayout from "./Baselayout.astro";
import { getLocale, type Lang } from "../i18n/utils";
import type { Translations } from "../i18n/types";
import GiscusComments from "../components/GiscusComments.astro";
import type { OgImage } from "../components/SEO.astro";

interface Props {
  frontmatter: {
    title: string;
    pubDate: Date;
    tags?: string[];
    description?: string;
  };
  lang: Lang;
  t: Translations;
  canonicalURL: string;
  noteId?: string;
  readingTime?: string;
  ogImage?: OgImage;
}

const { frontmatter, lang, t, canonicalURL, noteId, readingTime, ogImage } = Astro.props;
const locale = getLocale(lang);
---

<BaseLayout
  pageTitle={frontmatter.title}
  showTitle={false}
  lang={lang}
  t={t}
  seoDescription={frontmatter.description || frontmatter.title}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  seoType="article"
  pubDate={frontmatter.pubDate}
  tags={frontmatter.tags}
>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">
        {frontmatter.title}
      </h1>
      <div class="flex flex-wrap items-center gap-2 text-sm text-neutral-400">
        <time datetime={frontmatter.pubDate.toISOString()}>
          {frontmatter.pubDate.toLocaleDateString(locale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {readingTime && (
          <>
            <span aria-hidden="true">&middot;</span>
            <span class="inline-flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor" aria-hidden="true"><!--!Font Awesome Free v7.3.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M464 256a208 208 0 1 1 -416 0 208 208 0 1 1 416 0zM0 256a256 256 0 1 0 512 0 256 256 0 1 0 -512 0zM232 120l0 136c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2 280 120c0-13.3-10.7-24-24-24s-24 10.7-24 24z"/></svg>
              {readingTime}
            </span>
          </>
        )}
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <>
            <span aria-hidden="true">&middot;</span>
            <span class="flex flex-wrap gap-1.5">
              {frontmatter.tags.map((tag: string) => (
                <a
                  href={`/${lang}/tags/${tag}/`}
                  class="text-pink-600 hover:text-pink-800 transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </span>
          </>
        )}
      </div>
    </header>

    <div class="prose prose-neutral max-w-none">
      <slot />
    </div>

  </article>

  {noteId && <GiscusComments term={noteId} lang={lang} t={t} />}
</BaseLayout>
