---
import BaseLayout from "./Baselayout.astro";
import { getLocale, type Lang } from "../i18n/utils";
import type { Translations } from "../i18n/types";

interface Props {
  frontmatter: {
    title: string;
    pubDate: Date;
    tags?: string[];
    description?: string;
  };
  lang: Lang;
  t: Translations;
  canonicalURL: string;
}

const { frontmatter, lang, t, canonicalURL } = Astro.props;
const locale = getLocale(lang);
---

<BaseLayout
  pageTitle={frontmatter.title}
  showTitle={false}
  lang={lang}
  t={t}
  seoDescription={frontmatter.description || frontmatter.title}
  canonicalURL={canonicalURL}
  seoType="article"
  pubDate={frontmatter.pubDate}
  tags={frontmatter.tags}
>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">
        {frontmatter.title}
      </h1>
      <div class="flex flex-wrap items-center gap-2 text-sm text-neutral-400">
        <time datetime={frontmatter.pubDate.toISOString()}>
          {frontmatter.pubDate.toLocaleDateString(locale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <>
            <span aria-hidden="true">&middot;</span>
            <span class="flex flex-wrap gap-1.5">
              {frontmatter.tags.map((tag: string) => (
                <a
                  href={`/${lang}/tags/${tag}`}
                  class="text-pink-600 hover:text-pink-800 transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </span>
          </>
        )}
      </div>
    </header>

    <div class="prose prose-neutral max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
