---
import { getCollection, render } from "astro:content";
import MarkdownPostLayout from "../../../../layouts/MarkdownPostLayout.astro";
import { getReadingTime } from "../../../../utils/readingTime";
import { en } from "../../../../i18n/en";
import { zh } from "../../../../i18n/zh";
import type { Lang } from "../../../../i18n/utils";
import type { Translations } from "../../../../i18n/types";

export async function getStaticPaths() {
  const allNotes = await getCollection("notes");

  const paths: { params: { lang: string; category: string; slug: string }; props: { t: Translations; post: (typeof allNotes)[number]; readingTime: string } }[] = [];

  for (const note of allNotes) {
    const parts = note.id.split("/");
    const category = parts.length > 1 ? parts[0] : "others";
    const slug = parts.length > 1 ? parts.slice(1).join("/") : note.id;

    const rtEn = getReadingTime(note.body || "", "en");
    const rtZh = getReadingTime(note.body || "", "zh");

    paths.push({
      params: { lang: "en", category, slug },
      props: { t: en, post: note, readingTime: rtEn.full },
    });
    paths.push({
      params: { lang: "zh", category, slug },
      props: { t: zh, post: note, readingTime: rtZh.full },
    });
  }

  return paths;
}

const { lang } = Astro.params as { lang: Lang };
const { t, post, readingTime } = Astro.props as { t: Translations; post: any; readingTime?: string };
const { Content } = await render(post);
---

<MarkdownPostLayout
  frontmatter={post.data}
  lang={lang}
  t={t}
  canonicalURL={`/${lang}/notes/${post.id}/`}
  noteId={post.id}
  readingTime={readingTime}
  ogImage={post.data.image}
>
  <Content />
</MarkdownPostLayout>
