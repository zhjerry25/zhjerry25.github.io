---
import { render } from "astro:content";
import { getImage } from "astro:assets";
import MarkdownPostLayout from "../../../../layouts/MarkdownPostLayout.astro";
import { getReadingTime } from "../../../../utils/readingTime";
import { getAllNotes, type NoteEntry } from "../../../../utils/noteCollection";
import { noteURL, splitTranslationKey } from "../../../../utils/notes";
import { en } from "../../../../i18n/en";
import { zh } from "../../../../i18n/zh";
import type { Lang } from "../../../../i18n/utils";
import type { Translations } from "../../../../i18n/types";

export async function getStaticPaths() {
  const allNotes = await getAllNotes();
  const translations: Record<Lang, Translations> = { en, zh };

  const paths: { params: { lang: Lang; category: string; slug: string }; props: { t: Translations; post: NoteEntry; readingTime: string } }[] = [];

  for (const note of allNotes) {
    const { category, slug } = splitTranslationKey(note.data.translationKey);
    const lang = note.data.lang;
    const readingTime = getReadingTime(note.body || "", lang);
    paths.push({
      params: { lang, category, slug },
      props: { t: translations[lang], post: note, readingTime: readingTime.full },
    });
  }

  return paths;
}

const { lang } = Astro.params as { lang: Lang };
const { t, post, readingTime } = Astro.props as { t: Translations; post: NoteEntry; readingTime?: string };
const { Content } = await render(post);

// Resolve og:image via Astro's native image pipeline. The frontmatter `image`
// is an ImageMetadata (image() schema); render a single ~1200w variant and turn
// its root-relative src into an absolute URL + dimensions for SEO. Cap the
// requested width to the source's intrinsic width: sharp renders with
// withoutEnlargement, so an oversized request would report larger dimensions in
// the metadata than the actually-served (capped) image.
let ogImage: { url: string; width: number; height: number } | undefined;
if (post.data.image) {
  const targetWidth = Math.min(1200, post.data.image.width);
  const img = await getImage({ src: post.data.image, width: targetWidth, layout: "none" });
  ogImage = {
    url: new URL(img.src, Astro.site).href,
    width: Number(img.attributes.width),
    height: Number(img.attributes.height),
  };
}
---

<MarkdownPostLayout
  frontmatter={post.data}
  lang={lang}
  t={t}
  canonicalURL={noteURL(lang, post.data.translationKey)}
  translationKey={post.data.translationKey}
  readingTime={readingTime}
  ogImage={ogImage}
>
  <Content />
</MarkdownPostLayout>
