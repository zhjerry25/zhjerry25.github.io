---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MarkdownPostLayout from "../../../../layouts/MarkdownPostLayout.astro";
import { getReadingTime } from "../../../../utils/readingTime";
import { en } from "../../../../i18n/en";
import { zh } from "../../../../i18n/zh";
import type { Lang } from "../../../../i18n/utils";
import type { Translations } from "../../../../i18n/types";
import path from "node:path";
import fs from "node:fs";
import crypto from "node:crypto";
import sharp from "sharp";

type Note = CollectionEntry<"notes">;

const MAX_WIDTH = 800;
const WEBP_QUALITY = 80;
const OUTPUT_DIR = "dist/_images";

/** Resolve a frontmatter `image` field to the optimized og:image URL. */
async function resolveOgImage(imageField: string, noteId: string): Promise<string | undefined> {
  // Resolve the relative path against the note's directory
  const noteDir = path.dirname(path.join("src/notes", noteId));
  const imagePath = path.resolve(noteDir, imageField);

  if (!fs.existsSync(imagePath)) {
    console.warn(`[og-image] Image not found: ${imagePath}`);
    return undefined;
  }

  const buf = fs.readFileSync(imagePath);
  const hash = crypto.createHash("sha256").update(buf).digest("hex").slice(0, 12);

  // Generate optimized WebP if it doesn't exist yet (image may only be in frontmatter)
  const outputDir = path.resolve(OUTPUT_DIR);
  const webpPath = path.join(outputDir, `${hash}.webp`);
  if (!fs.existsSync(webpPath)) {
    try {
      const metadata = await sharp(buf).metadata();
      if (metadata.width) {
        const w = Math.min(metadata.width, MAX_WIDTH);
        const aspect = metadata.height ? metadata.height / metadata.width : 1;
        const h = Math.round(w * aspect);
        if (!fs.existsSync(outputDir)) {
          fs.mkdirSync(outputDir, { recursive: true });
        }
        await sharp(buf)
          .resize(w, h, { fit: "inside", withoutEnlargement: true })
          .webp({ quality: WEBP_QUALITY })
          .toFile(webpPath);
      }
    } catch (err) {
      console.warn(`[og-image] Failed to process ${imageField}:`, err);
      return undefined;
    }
  }

  return `/_images/${hash}.webp`;
}

export async function getStaticPaths() {
  const allNotes = await getCollection("notes");

  const paths: { params: { lang: string; category: string; slug: string }; props: { t: Translations; post: Note; readingTime: string } }[] = [];

  for (const note of allNotes) {
    const parts = note.id.split("/");
    const category = parts.length > 1 ? parts[0] : "others";
    const slug = parts.length > 1 ? parts.slice(1).join("/") : note.id;

    const rtEn = getReadingTime(note.body || "", "en");
    const rtZh = getReadingTime(note.body || "", "zh");

    paths.push({
      params: { lang: "en", category, slug },
      props: { t: en, post: note, readingTime: rtEn.full },
    });
    paths.push({
      params: { lang: "zh", category, slug },
      props: { t: zh, post: note, readingTime: rtZh.full },
    });
  }

  return paths;
}

const { lang } = Astro.params as { lang: Lang };
const { t, post, readingTime } = Astro.props as { t: Translations; post: Note; readingTime?: string };
const { Content } = await render(post);

// Resolve og:image — frontmatter stores a co-located relative path (e.g. "./cover.png"),
// but we need the optimized /_images/<hash>.webp URL for social sharing.
const ogImage = post.data.image
  ? await resolveOgImage(post.data.image, post.id)
  : undefined;
---

<MarkdownPostLayout
  frontmatter={post.data}
  lang={lang}
  t={t}
  canonicalURL={`/${lang}/notes/${post.id}/`}
  noteId={post.id}
  readingTime={readingTime}
  ogImage={ogImage}
>
  <Content />
</MarkdownPostLayout>
