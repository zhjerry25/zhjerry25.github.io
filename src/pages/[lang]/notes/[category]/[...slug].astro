---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { getImage } from "astro:assets";
import MarkdownPostLayout from "../../../../layouts/MarkdownPostLayout.astro";
import { getReadingTime } from "../../../../utils/readingTime";
import { noteURL, splitNoteId } from "../../../../utils/notes";
import { en } from "../../../../i18n/en";
import { zh } from "../../../../i18n/zh";
import type { Lang } from "../../../../i18n/utils";
import type { Translations } from "../../../../i18n/types";

type Note = CollectionEntry<"notes">;

export async function getStaticPaths() {
  const allNotes = await getCollection("notes");

  const paths: { params: { lang: string; category: string; slug: string }; props: { t: Translations; post: Note; readingTime: string } }[] = [];

  for (const note of allNotes) {
    const { category, slug } = splitNoteId(note.id);

    const rtEn = getReadingTime(note.body || "", "en");
    const rtZh = getReadingTime(note.body || "", "zh");

    paths.push({
      params: { lang: "en", category, slug },
      props: { t: en, post: note, readingTime: rtEn.full },
    });
    paths.push({
      params: { lang: "zh", category, slug },
      props: { t: zh, post: note, readingTime: rtZh.full },
    });
  }

  return paths;
}

const { lang } = Astro.params as { lang: Lang };
const { t, post, readingTime } = Astro.props as { t: Translations; post: Note; readingTime?: string };
const { Content } = await render(post);

// Resolve og:image via Astro's native image pipeline. The frontmatter `image`
// is an ImageMetadata (image() schema); render a single ~1200w variant and turn
// its root-relative src into an absolute URL + dimensions for SEO. Cap the
// requested width to the source's intrinsic width: sharp renders with
// withoutEnlargement, so an oversized request would report larger dimensions in
// the metadata than the actually-served (capped) image.
let ogImage: { url: string; width: number; height: number } | undefined;
if (post.data.image) {
  const targetWidth = Math.min(1200, post.data.image.width);
  const img = await getImage({ src: post.data.image, width: targetWidth, layout: "none" });
  ogImage = {
    url: new URL(img.src, Astro.site).href,
    width: Number(img.attributes.width),
    height: Number(img.attributes.height),
  };
}
---

<MarkdownPostLayout
  frontmatter={post.data}
  lang={lang}
  t={t}
  canonicalURL={noteURL(lang, post.id)}
  noteId={post.id}
  readingTime={readingTime}
  ogImage={ogImage}
>
  <Content />
</MarkdownPostLayout>
