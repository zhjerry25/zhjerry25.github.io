---
import BaseLayout from "../../../../layouts/Baselayout.astro";
import BlogPost from "../../../../components/BlogPost.astro";
import { getReadingTime } from "../../../../utils/readingTime";
import { getAllNotes, getLocalizedNotes } from "../../../../utils/noteCollection";
import { noteURL, splitTranslationKey } from "../../../../utils/notes";
import { getLocale, type Lang } from "../../../../i18n/utils";
import { en } from "../../../../i18n/en";
import { zh } from "../../../../i18n/zh";
import type { Translations } from "../../../../i18n/types";

export async function getStaticPaths() {
  // Always generate pages for the categories linked in the sidebar/home, plus
  // any new category that has notes (so a new notes/<dir>/ is never a 404).
  // Categories without notes render the empty state.
  const NAV_CATEGORIES = ["chem", "cs", "mathphy", "others"] as const;
  const allNotes = await getAllNotes();
  const derived = allNotes.map((note) =>
    splitTranslationKey(note.data.translationKey).category
  );
  const categories = [...new Set([...NAV_CATEGORIES, ...derived])];

  const paths: { params: { lang: string; category: string }; props: { t: Translations } }[] = [];
  for (const cat of categories) {
    paths.push({ params: { lang: "en", category: cat }, props: { t: en } });
    paths.push({ params: { lang: "zh", category: cat }, props: { t: zh } });
  }
  return paths;
}

const { lang, category } = Astro.params as { lang: Lang; category: string };
const { t } = Astro.props as { t: Translations };
const locale = getLocale(lang);

const allNotes = await getLocalizedNotes(lang);
const posts = allNotes
  .filter(
    (note) =>
      splitTranslationKey(note.data.translationKey).category === category
  )
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = (d: Date) =>
  d.toLocaleDateString(locale, { year: "numeric", month: "short", day: "numeric" });

const categoryLabel = t.categories[category as keyof typeof t.categories] || category;
const catMeta = t.categoryMeta[category as keyof typeof t.categoryMeta];
---

<BaseLayout
  pageTitle={categoryLabel}
  lang={lang}
  t={t}
  seoDescription={catMeta?.desc || `${categoryLabel} notes`}
  canonicalURL={`/${lang}/notes/${category}/`}
>
  <p class="text-neutral-500 mb-6">{catMeta?.desc || ""}</p>

  {posts.length > 0 ? (
    <div class="space-y-3">
      {posts.map((note) => {
        const { short: readingTime } = getReadingTime(note.body || "", lang);
        return (
          <BlogPost
            title={note.data.title}
            url={noteURL(lang, note.data.translationKey)}
            date={formatDate(note.data.pubDate)}
            tags={note.data.tags}
            description={note.data.description}
            translationKey={note.data.translationKey}
            readingTime={readingTime}
          />
        );
      })}
    </div>
  ) : (
    <p class="text-neutral-400 text-sm">{t.notes.empty}</p>
  )}
</BaseLayout>
