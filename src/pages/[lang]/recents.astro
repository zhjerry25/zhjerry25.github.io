---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/Baselayout.astro";
import BlogPost from "../../components/BlogPost.astro";
import { getReadingTime } from "../../utils/readingTime";
import { noteURL, splitNoteId } from "../../utils/notes";
import { getLocale, type Lang } from "../../i18n/utils";
import { en } from "../../i18n/en";
import { zh } from "../../i18n/zh";
import type { Translations } from "../../i18n/types";

export function getStaticPaths() {
  return [
    { params: { lang: "en" }, props: { t: en } },
    { params: { lang: "zh" }, props: { t: zh } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const { t } = Astro.props as { t: Translations };
const locale = getLocale(lang);

const allNotes = await getCollection("notes");

const getCategoryLabel = (id: string): string => {
  const { category } = splitNoteId(id);
  return t.categories[category as keyof typeof t.categories] || category;
};

const formatDate = (d: Date) =>
  d.toLocaleDateString(locale, { year: "numeric", month: "short", day: "numeric" });

const sortedNotes = allNotes.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const recentNotes = sortedNotes.slice(0, 5);
---

<BaseLayout
  pageTitle={t.recents.title}
  lang={lang}
  t={t}
  seoDescription={t.seo.recentsDescription}
  canonicalURL={`/${lang}/recents/`}
  searchable={false}
>
  <p class="text-neutral-500 mb-6">{t.recents.description}</p>

  {recentNotes.length > 0 ? (
    <div class="space-y-3">
      {recentNotes.map((note) => {
        const { short: readingTime } = getReadingTime(note.body || "", lang);
        return (
          <BlogPost
            title={note.data.title}
            url={noteURL(lang, note.id)}
            label={getCategoryLabel(note.id)}
            date={formatDate(note.data.pubDate)}
            description={note.data.description}
            noteId={note.id}
            readingTime={readingTime}
          />
        );
      })}
    </div>
  ) : (
    <p class="text-neutral-400 text-sm">{t.recents.empty}</p>
  )}
</BaseLayout>
