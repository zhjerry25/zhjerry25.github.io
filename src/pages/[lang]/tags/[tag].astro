---
import BaseLayout from "../../../layouts/Baselayout.astro";
import { getReadingTime } from "../../../utils/readingTime";
import { getAllNotes, getLocalizedNotes } from "../../../utils/noteCollection";
import { noteURL } from "../../../utils/notes";
import { getLocale, type Lang } from "../../../i18n/utils";
import { en } from "../../../i18n/en";
import { zh } from "../../../i18n/zh";
import type { Translations } from "../../../i18n/types";

export async function getStaticPaths() {
  const allNotes = await getAllNotes();
  const uniqueTags = [...new Set(allNotes.map((note) => note.data.tags).flat())];

  const paths: { params: { lang: string; tag: string }; props: { t: Translations } }[] = [];
  for (const tag of uniqueTags) {
    paths.push({ params: { lang: "en", tag }, props: { t: en } });
    paths.push({ params: { lang: "zh", tag }, props: { t: zh } });
  }
  return paths;
}

const { lang, tag } = Astro.params as { lang: Lang; tag: string };
const { t } = Astro.props as { t: Translations };
const locale = getLocale(lang);

const allNotes = await getLocalizedNotes(lang);
const notes = allNotes.filter((note) =>
  note.data.tags.includes(tag!)
);
---

<BaseLayout
  pageTitle={`#${tag}`}
  lang={lang}
  t={t}
  seoDescription={`${t.tags.notesCount(notes.length, tag)}#${tag}`}
  canonicalURL={`/${lang}/tags/${tag}/`}
>
  <p class="text-neutral-500 mb-6">
    {t.tags.notesCount(notes.length, tag!)}
    <span class="font-medium text-pink-600">#{tag}</span>
  </p>

  <div class="space-y-3">
    {notes.map((note) => {
      const { short: readingTime } = getReadingTime(note.body || "", lang);
      return (
        <a
          href={noteURL(lang, note.data.translationKey)}
          class="block rounded-lg border border-neutral-200 p-4 hover:border-neutral-300 hover:bg-neutral-50 transition-colors"
          data-pagefind-ignore
        >
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs text-neutral-400">
              {note.data.pubDate.toLocaleDateString(locale, {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </span>
            {readingTime && (
              <span class="inline-flex items-center gap-1 text-xs text-neutral-400">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor" aria-hidden="true"><!--!Font Awesome Free v7.3.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M464 256a208 208 0 1 1 -416 0 208 208 0 1 1 416 0zM0 256a256 256 0 1 0 512 0 256 256 0 1 0 -512 0zM232 120l0 136c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2 280 120c0-13.3-10.7-24-24-24s-24 10.7-24 24z"/></svg>
                {readingTime}
              </span>
            )}
            <span class="flex gap-1">
              {note.data.tags.map((tg: string) => (
                <span class="text-xs text-pink-600 bg-pink-50 px-1.5 py-0.5 rounded">
                  {tg}
                </span>
              ))}
            </span>
          </div>
          <h3 class="text-base font-medium text-gray-900">{note.data.title}</h3>
          {note.data.description && (
            <p class="text-sm text-neutral-500 mt-1">{note.data.description}</p>
          )}
        </a>
      );
    })}
  </div>
</BaseLayout>
