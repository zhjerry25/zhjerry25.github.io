---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/Baselayout.astro";
import { en } from "../../../i18n/en";
import { zh } from "../../../i18n/zh";
import type { Lang } from "../../../i18n/utils";
import type { Translations } from "../../../i18n/types";

export function getStaticPaths() {
  return [
    { params: { lang: "en" }, props: { t: en } },
    { params: { lang: "zh" }, props: { t: zh } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const { t } = Astro.props as { t: Translations };

const allNotes = await getCollection("notes");
const tags = [...new Set(allNotes.map((note) => note.data.tags).flat())].sort();
---

<BaseLayout
  pageTitle={t.tags.title}
  lang={lang}
  t={t}
  seoDescription={t.seo.tagsDescription}
  canonicalURL={`/${lang}/tags/`}
>
  <p class="text-neutral-500 mb-6">
    {t.tags.tagCount(tags.length)}
  </p>

  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <a
        href={`/${lang}/tags/${tag}/`}
        class="inline-block rounded-full bg-pink-50 px-3 py-1.5 text-sm text-pink-700 hover:bg-pink-100 transition-colors"
      >
        #{tag}
      </a>
    ))}
  </div>
</BaseLayout>
