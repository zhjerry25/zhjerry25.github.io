---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/Baselayout.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag)
    );
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout pageTitle={tag!}>
  <p class="text-neutral-500 mb-6">
    {posts.length} {posts.length === 1 ? "post" : "posts"} tagged with <span class="font-medium text-pink-600">#{tag}</span>.
  </p>

  <div class="space-y-3">
    {posts.map((post: any) => (
      <a
        href={`/posts/${post.id}/`}
        class="block rounded-lg border border-neutral-200 p-4 hover:border-neutral-300 hover:bg-neutral-50 transition-colors"
      >
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs text-neutral-400">
            {post.data.pubDate.toLocaleDateString("zh-cn", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </span>
          <span class="flex gap-1">
            {post.data.tags.map((t: string) => (
              <span class="text-xs text-pink-600 bg-pink-50 px-1.5 py-0.5 rounded">
                {t}
              </span>
            ))}
          </span>
        </div>
        <h3 class="text-base font-medium text-gray-900">{post.data.title}</h3>
        {post.data.description && (
          <p class="text-sm text-neutral-500 mt-1">{post.data.description}</p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
