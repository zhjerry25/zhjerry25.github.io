---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/Baselayout.astro";

const allNotes = await getCollection("notes");
const tags = [...new Set(allNotes.map((note) => note.data.tags).flat())].sort();
const pageTitle = "Tags";
---

<BaseLayout pageTitle={pageTitle}>
  <p class="text-neutral-500 mb-6">
    {tags.length} {tags.length === 1 ? "tag" : "tags"} across all notes.
  </p>

  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag}`}
        class="inline-block rounded-full bg-pink-50 px-3 py-1.5 text-sm text-pink-700 hover:bg-pink-100 transition-colors"
      >
        #{tag}
      </a>
    ))}
  </div>
</BaseLayout>
